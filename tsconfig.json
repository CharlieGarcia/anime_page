{
  "compilerOptions": {
    "target": "ESNext",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "paths": {
      "@/components/*": [
        "./src/components/*"
      ],
      "@/hooks/*": [
        "./src/hooks/*"
      ],
      "@/helpers/*": [
        "./src/helpers/*"
      ],
      "@/pages/*": [
        "./src/pages/*"
      ],
      "@/public/*": [
        "./src/public/*"
      ],
      "@/styles/*": [
        "./src/styles/*"
      ],
      "@/constants": [
        "./src/constants"
      ],
      "@/types": [
        "./src/types"
      ]
    },
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "next-env.d.ts",
    "**/*.mts",
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}
